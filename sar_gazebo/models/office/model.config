<?xml version="1.0"?>
<model>
  <name>office</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>Alvaro J. Gaona</name>
    <email>alvgaona@gmail.com</email>
  </author>
  <description>
    Office layout imported from CAD STL export. Source units are millimetres
    with Y-axis up; the SDF applies a 0.001 scale and a roll of pi/2 to align
    with Gazebo's Z-up convention.
  </description>
</model>
